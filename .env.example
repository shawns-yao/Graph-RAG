# LLM provider (OpenAI-compatible)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MODEL_MINI=deepseek-chat
LLM_TEMPERATURE=0.0

# Embedding provider (OpenAI-compatible)
# Leave EMBEDDING_API_KEY / EMBEDDING_BASE_URL empty to reuse the LLM provider.
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1536

# Backward-compatible OpenAI variable names
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_LLM_MODEL=
# OPENAI_LLM_MODEL_MINI=
# OPENAI_EMBEDDING_MODEL=
# OPENAI_EMBEDDING_DIMENSIONS=1536
# OPENAI_LLM_TEMPERATURE=0.0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# Indexing
INDEXING_STRUCTURED_CHUNKING_ENABLED=true
INDEXING_HIERARCHICAL_CHUNKING_ENABLED=true
INDEXING_GRAPH_CHUNKING_ENABLED=true
INDEXING_CHUNK_SIZE=1000
INDEXING_CHUNK_OVERLAP=200
INDEXING_PARENT_CHUNK_SIZE=4000
INDEXING_CONTEXT_WINDOW_CHARS=1200
INDEXING_GRAPH_SKELETON_CHUNK_SIZE=3000
INDEXING_GRAPH_SKELETON_CHUNK_MAX_SIZE=4200
INDEXING_GRAPH_PERIPHERAL_CHUNK_SIZE=1000
INDEXING_GRAPH_MIN_ENTITIES_PER_CHUNK=2
INDEXING_GRAPH_SENTENCE_BOUNDARY_ONLY=true
INDEXING_SKELETON_ENTITY_DENSITY_WEIGHT=0.35
INDEXING_SKELETON_BETA=0.25
INDEXING_SKELETON_BETA_SHORT_DOC=1.0
INDEXING_SKELETON_BETA_MEDIUM_DOC=0.5
INDEXING_SKELETON_BETA_LONG_DOC=0.3
INDEXING_SKELETON_SHORT_DOC_MAX_CHUNKS=8
INDEXING_SKELETON_MEDIUM_DOC_MAX_CHUNKS=24
INDEXING_KNN_K=5
INDEXING_PAGERANK_DAMPING=0.85
INDEXING_PAGERANK_DAMPING_TECHNICAL=0.8
INDEXING_PAGERANK_DAMPING_PAPER=0.9
INDEXING_TFIDF_LOW_IDF_THRESHOLD=1.2
INDEXING_TFIDF_LOW_INFO_CHUNK_SCORE_THRESHOLD=0.6
INDEXING_TFIDF_MAX_KEYWORDS=8

# Retrieval
RETRIEVAL_TOP_K_VECTOR=10
RETRIEVAL_TOP_K_BM25=10
RETRIEVAL_TOP_K_FINAL=10
RETRIEVAL_PROMPT_MAX_CHUNKS=10
RETRIEVAL_PROMPT_MAX_CHARS=18000
RETRIEVAL_VECTOR_THRESHOLD=0.5
RETRIEVAL_MAX_HOPS=2
RETRIEVAL_GRAPH_ENTRY_TOP_K=5
RETRIEVAL_GRAPH_COOCCURRENCE_LIMIT=32
RETRIEVAL_GRAPH_PASSAGE_LIMIT=12
RETRIEVAL_PPR_ALPHA=0.15
RETRIEVAL_RRF_K=60
RETRIEVAL_FANOUT_MAX_WORKERS=3
RETRIEVAL_FANOUT_TIMEOUT_MS=15000
RETRIEVAL_FULLTEXT_INDEX_NAME=passage_text_index
RETRIEVAL_RERANKER_BACKEND=lexical_semantic
RETRIEVAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_EMPTY_CHANNEL_PENALTY=0.35
RETRIEVAL_SPARSE_CHANNEL_PENALTY=0.75
RETRIEVAL_WEAK_CHANNEL_MIN_RESULTS=2
RETRIEVAL_BM25_LEXICAL_BOOST=1.2
RETRIEVAL_GRAPH_EVIDENCE_BOOST=1.1
RETRIEVAL_LEXICAL_OVERLAP_THRESHOLD=0.5
RETRIEVAL_TFIDF_QUERY_MIN_IDF=1.2
RETRIEVAL_TFIDF_QUERY_MAX_KEYWORDS=6
RETRIEVAL_CONFIDENCE_MIN=0.1

# Agent
AGENT_MAX_RETRIES=1
AGENT_MAX_RERANKS=1
AGENT_MAX_QUERY_REWRITES=0
AGENT_REQUEST_TIME_BUDGET_MS=1500
AGENT_RELEVANCE_THRESHOLD=2.0
AGENT_REFLECTION_SKIP_SCORE_THRESHOLD=0.85

# Benchmark
BENCHMARK_LLM_MAX_RETRIES=2
BENCHMARK_LLM_CONNECT_TIMEOUT_SECONDS=5.0
BENCHMARK_LLM_READ_TIMEOUT_SECONDS=30.0
BENCHMARK_LLM_WRITE_TIMEOUT_SECONDS=30.0
BENCHMARK_LLM_POOL_TIMEOUT_SECONDS=30.0
BENCHMARK_LLM_INITIAL_BACKOFF_SECONDS=2.0
BENCHMARK_LLM_MAX_BACKOFF_SECONDS=12.0
BENCHMARK_LLM_JITTER_SECONDS=0.25
BENCHMARK_LLM_MAX_PARALLEL_REQUESTS=1
BENCHMARK_LLM_MIN_REQUEST_INTERVAL_MS=750

# Ingest
INGEST_LLM_MAX_RETRIES=5
INGEST_LLM_CONNECT_TIMEOUT_SECONDS=5.0
INGEST_LLM_READ_TIMEOUT_SECONDS=45.0
INGEST_LLM_WRITE_TIMEOUT_SECONDS=45.0
INGEST_LLM_POOL_TIMEOUT_SECONDS=45.0
INGEST_LLM_INITIAL_BACKOFF_SECONDS=2.0
INGEST_LLM_MAX_BACKOFF_SECONDS=8.0
INGEST_LLM_JITTER_SECONDS=0.25
INGEST_LLM_MAX_CONSECUTIVE_FAILURES=3
INGEST_LLM_TOTAL_BUDGET_SECONDS=600.0
INGEST_EMBEDDING_BATCH_SIZE=64

# API / UI
AGR_API_URL=http://localhost:8507

# Logging
LOG_LEVEL=INFO
